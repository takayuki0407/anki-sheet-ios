# Anki-sheet — client (publishable) config. Copy this file to `.env` and fill in the values.
# All EXPO_PUBLIC_* vars are inlined into the app bundle at build time (Expo auto-loads `.env`
# for `npx expo start`). These are PUBLISHABLE client keys (safe to ship in a client app);
# `.env` is gitignored by convention so each developer keeps their own.
#
# IMPORTANT — EAS cloud builds do NOT receive `.env` (it's gitignored / untracked, so it isn't
# uploaded). For `eas build`, also register each var as an EAS environment variable, e.g.:
#   eas env:create --environment production --name EXPO_PUBLIC_FIREBASE_API_KEY --value "..." --visibility plaintext
# (repeat per var, per environment) — see the setup checklist.

# --- Firebase (Firebase console → Project settings → Your apps → Web app </>) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- RevenueCat (Project → API keys → Public app-specific key for the iOS app; starts with "appl_") ---
EXPO_PUBLIC_RC_IOS_KEY=

# Optional, only if you later add an Android build:
# EXPO_PUBLIC_RC_ANDROID_KEY=
